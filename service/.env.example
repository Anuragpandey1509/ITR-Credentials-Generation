# ============================================================
# ITR Service — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env — it is in .gitignore.
# ============================================================

# MongoDB — Local instance (connect with MongoDB Compass at mongodb://localhost:27017)
# For Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/itr-credentials
MONGODB_URI=mongodb://localhost:27017/itr-credentials

# Server
PORT=4000
NODE_ENV=development

# API auth — operators/UI must send this as: Authorization: Bearer <token>
# Generate a strong random token: openssl rand -hex 32
API_BEARER_TOKEN=your-strong-bearer-token-here

# Webhook auth — automation bot must send this header: X-Webhook-Secret: <secret>
# Must match WEBHOOK_SECRET in automation/.env
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret-here

# AES-256-GCM key (exactly 64 hex characters = 32 bytes) — used to encrypt PAN & passwords at rest
# Must match ENCRYPTION_KEY in automation/.env
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-key-here

# SSE ring buffer size (events kept in memory for zero-latency fan-out)
RING_BUFFER_SIZE=500

# Log level: trace | debug | info | warn | error
LOG_LEVEL=debug
