# ============================================================
# ITR Automation — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env — it is in .gitignore.
# ============================================================

# Service base URL (where the service is running)
SERVICE_URL=http://localhost:4000

# Webhook secret — must match WEBHOOK_SECRET in service/.env
WEBHOOK_SECRET=your-webhook-secret-here

# AES-256-GCM key — must match ENCRYPTION_KEY in service/.env
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-key-here

# Playwright browser settings
# Set HEADLESS=false to watch the browser during a demo
HEADLESS=false
STEP_TIMEOUT_MS=30000

# Polling limits
# OTP: bot polls for operator input every 5s; 120 attempts = 10 minutes total
OTP_POLL_MAX_ATTEMPTS=120
# CAPTCHA: 30 attempts = 2.5 minutes total
CAPTCHA_POLL_MAX_ATTEMPTS=30
# Webhook delivery retries with exponential backoff (500ms → 16s)
WEBHOOK_RETRIES=5

# IT portal URL
PORTAL_URL=https://www.incometax.gov.in/iec/foportal/

# Log level: trace | debug | info | warn | error
LOG_LEVEL=debug
NODE_ENV=development
